<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; color: #2A2118; background: #fff; }
    .statement { max-width: 800px; margin: 0 auto; padding: 40px; }
    .header { border-bottom: 2px solid #6B1D24; padding-bottom: 20px; margin-bottom: 24px; }
    .header h1 { font-size: 22px; color: #6B1D24; }
    .header .address { font-size: 12px; color: #888; margin-top: 4px; }
    .header .title { font-size: 16px; font-weight: 600; color: #C9A227; margin-top: 16px; text-transform: uppercase; letter-spacing: 2px; }
    .meta { display: flex; justify-content: space-between; margin-bottom: 24px; font-size: 13px; }
    .meta .label { color: #888; }
    .meta .value { font-weight: 600; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 24px; font-size: 12px; }
    thead th { background: #6B1D24; color: #fff; padding: 10px 8px; text-align: left; font-weight: 500; }
    thead th:last-child { text-align: right; }
    tbody td { padding: 8px; border-bottom: 1px solid #f0ebe0; }
    tbody td:last-child { text-align: right; font-variant-numeric: tabular-nums; }
    tbody tr:nth-child(even) { background: #faf8f3; }
    .total-row { font-weight: 700; font-size: 14px; border-top: 2px solid #C9A227; }
    .total-row td { padding: 12px 8px; }
    .footer { border-top: 1px solid #e0d8c8; padding-top: 16px; font-size: 11px; color: #888; }
    .footer p { margin: 2px 0; }
    @media print { body { padding: 0; } .statement { padding: 20px; } }
  </style>
</head>
<body>
  <div class="statement">
    <div class="header">
      <h1>{{templeName}}</h1>
      <div class="address">{{templeAddress}}</div>
      {{#if registrationNumber}}<div class="address">Registration No: {{registrationNumber}}</div>{{/if}}
      <div class="title">Donation Statement</div>
    </div>

    <div class="meta">
      <div>
        <div class="label">Statement Period</div>
        <div class="value">{{periodStart}} — {{periodEnd}}</div>
      </div>
      <div style="text-align: right;">
        <div class="label">Generated</div>
        <div class="value">{{generatedAt}}</div>
        <div class="label" style="margin-top: 4px;">Generated By</div>
        <div class="value">{{generatedBy}}</div>
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Donor Name</th>
          <th>Receipt No.</th>
          <th>Transaction ID</th>
          <th>Date</th>
          <th>Amount (₹)</th>
        </tr>
      </thead>
      <tbody>
        {{#each donations}}
        <tr>
          <td>{{@index}}</td>
          <td>{{this.donorName}}</td>
          <td>{{this.receiptNumber}}</td>
          <td style="font-family: monospace; font-size: 11px;">{{this.transactionId}}</td>
          <td>{{this.date}}</td>
          <td>{{this.amount}}</td>
        </tr>
        {{/each}}
        <tr class="total-row">
          <td colspan="5" style="text-align: right;">Grand Total</td>
          <td>₹{{grandTotal}}</td>
        </tr>
      </tbody>
    </table>

    <div class="footer">
      <p>{{templeName}} | {{templeAddress}}</p>
      <p>This statement was generated on {{generatedAt}} and contains {{donations.length}} donation(s).</p>
      <p>This is a computer-generated report.</p>
    </div>
  </div>
</body>
</html>
