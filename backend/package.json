{
  "name": "temple-donations-backend",
  "version": "1.0.0",
  "description": "Temple Donation Management Platform — Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run copy-templates",
    "copy-templates": "node -e \"const fs=require('fs');const path=require('path');const dirs=[['src/services/pdf/templates','dist/services/pdf/templates'],['src/services/email/templates','dist/services/email/templates']];dirs.forEach(([s,d])=>{if(fs.existsSync(s)){fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).filter(f=>f.endsWith('.hbs')).forEach(f=>fs.copyFileSync(path.join(s,f),path.join(d,f)))}});console.log('✅ Templates copied to dist/')\"",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "seed:prod": "node dist/scripts/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@getbrevo/brevo": "^2.0.0",
    "@google/generative-ai": "^0.24.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "exifr": "^7.1.3",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "puppeteer": "^23.4.0",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.1.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.11.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
